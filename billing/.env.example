# Lumi Pro billing — webhook environment variables.
# Set these on your host (Vercel → Settings → Environment Variables). NEVER commit real values.

# Stripe — Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx

# Stripe — Dashboard → Developers → Webhooks → (your endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Your Ed25519 PRIVATE key PEM (the half you generated with
# `node core/scripts/make-license-keypair.mjs`). Paste the WHOLE PEM including the
# -----BEGIN/END PRIVATE KEY----- lines. Keep it secret; rotate if it ever leaks.
LUMI_LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Email delivery (Resend → API Keys). Swap emailLicense() for Postmark/SES if you prefer.
RESEND_API_KEY=re_xxx
LUMI_FROM_EMAIL=Lumi <hello@lumi.dev>
