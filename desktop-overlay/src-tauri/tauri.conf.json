{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumi",
  "version": "0.1.0",
  "identifier": "app.lumi.overlay",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lumi",
        "width": 400,
        "height": 640,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#1a1411",
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "externalBin": ["binaries/lumi-serve"]
  }
}
