{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumi Overlay",
  "version": "0.1.0",
  "identifier": "com.lumi.overlay",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Lumi",
        "width": 420,
        "height": 620,
        "minWidth": 320,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
